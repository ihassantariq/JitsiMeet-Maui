<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net9.0-android;net9.0-ios</TargetFrameworks>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">15.1</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">24.0</SupportedOSPlatformVersion>

    <!-- NuGet Package Metadata -->
    <IsPackable>true</IsPackable>
    <PackageId>JitsiMeet.Maui</PackageId>
    <Version>1.0.0</Version>
    <Authors>andersonvieiragomeslopes</Authors>
    <Description>Jitsi Meet plugin for .NET MAUI. Provides a cross-platform API to integrate Jitsi Meet video conferencing into .NET MAUI applications on Android and iOS.</Description>
    <PackageTags>jitsi;meet;maui;dotnet;video;conference;webrtc</PackageTags>
    <RepositoryUrl>https://github.com/andersonvieiragomeslopes/JitsiMeet-Maui</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" Version="$(MauiVersion)" />
    <PackageReference Include="Microsoft.Maui.Essentials" Version="$(MauiVersion)" />
  </ItemGroup>

  <!-- Android-specific references -->
  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">
    <ProjectReference Include="..\JitsiMeet.Android.Binding\JitsiMeet.Android.Binding.csproj" />
    <AndroidLibrary Include="..\NativeBinaries\android\deps\*.aar" Bind="false" />
    <AndroidLibrary Include="..\NativeBinaries\android\deps\*.jar" Bind="false" />
  </ItemGroup>

  <!-- iOS-specific references -->
  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
    <ProjectReference Include="..\JitsiMeet.iOS.Binding\JitsiMeet.iOS.Binding.csproj" />
    <NativeReference Include="..\NativeBinaries\ios\JitsiMeetSDK.xcframework">
      <Kind>Framework</Kind>
      <IsStatic>False</IsStatic>
    </NativeReference>
    <NativeReference Include="..\NativeBinaries\ios\hermes.xcframework">
      <Kind>Framework</Kind>
      <IsStatic>False</IsStatic>
    </NativeReference>
    <NativeReference Include="..\NativeBinaries\ios\GiphyUISDK.xcframework">
      <Kind>Framework</Kind>
      <IsStatic>False</IsStatic>
    </NativeReference>
    <NativeReference Include="..\NativeBinaries\ios\WebRTC.xcframework">
      <Kind>Framework</Kind>
      <IsStatic>False</IsStatic>
    </NativeReference>
  </ItemGroup>

</Project>
